{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "LicenseVault",
  "version": "1.0.0",
  "identifier": "com.licensevault.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5000",
    "beforeBuildCommand": "",
    "frontendDist": "../dist/public"
  },
  "app": {
    "windows": [
      {
        "title": "LicenseVault",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/licensevault-server"
    ]
  }
}
